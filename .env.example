# ==============================================================================
# ScanOPS - Environment Configuration Example
# Copy this file to .env and adjust the values as needed.
# ==============================================================================

# DATABASE (Obligatorio)
# URL de conexión a la base de datos PostgreSQL
DATABASE_URL=postgresql://user:pass@localhost/scanops

# REDIS (Obligatorio)
# URL de conexión para Celery y Caching
REDIS_URL=redis://localhost:6379/0
# Redis Streaming
REDIS_FINDINGS_CHANNEL=findings:scan:*
REDIS_TIMEOUT=30.0

# VAULT (Obligatorio)
# Dirección del servidor HashiCorp Vault para gestión de secretos
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=your-root-token-here

# SCANNER - OpenVAS (Opcional)
# Configuración para el motor de escaneo de vulnerabilidades OpenVAS/GVM
OPENVAS_HOST=localhost
OPENVAS_USER=admin
OPENVAS_PASS=your-password-here

# SCANNER - ZAP (Opcional)
# Configuración para OWASP ZAP Proxy
ZAP_HOST=localhost
ZAP_PORT=8080

# SCANNER - Nuclei (Opcional)
# Ruta al directorio de plantillas de Nuclei
NUCLEI_TEMPLATES=/path/to/templates

# GENERAL CONFIGURATION
# Nivel de logging y concurrencia
LOG_LEVEL=INFO
MAX_CONCURRENT_SCANS=5

# STREAMING PROCESSOR
STREAMING_PROCESSOR_ENABLED=true
STREAMING_BATCH_SIZE=10
STREAMING_TIMEOUT=300.0
STREAMING_RETRY_ATTEMPTS=3

# ==============================================================================
# M4 - EXPLOIT ENGINE
# ==============================================================================

# M4 - Tiempo máximo para que el operador apruebe (horas, default 24)
M4_APPROVAL_TIMEOUT_HOURS=24

# M4 - Ubuntu Server de pruebas
UBUNTU_TEST_TARGET_IP=10.202.15.100
UBUNTU_TEST_SSH_USER=admin

# M4 - Dry run: simula ejecución sin lanzar herramientas reales
M4_DRY_RUN=false

# ==============================================================================
# JWT AUTHENTICATION (ENS op.acc.1, op.acc.4, op.acc.5)
# ==============================================================================

# Secret key for signing JWT tokens — MUST be changed in production (min 32 chars)
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_32_CHARS_MIN

# Access token lifetime in minutes (default 480 = 8 hours)
JWT_ACCESS_EXPIRE_MINUTES=480

# Refresh token lifetime in days (default 7)
JWT_REFRESH_EXPIRE_DAYS=7

# M4 - Reintentos máximos de Hydra ante fallos (default 2)
M4_HYDRA_MAX_RETRIES=2