# ========================================
# ScanOPS - Production Environment
# ========================================
# Instructions:
# 1. Copy this file to .env.production
# 2. Replace all CHANGE_ME values with real credentials
# 3. NEVER commit .env.production to git
# 4. Ensure .env.production is in .gitignore

# ========== CRITICAL VARIABLES ==========
# These MUST be configured before deployment

# === Database (PostgreSQL) ===
DB_HOST=postgres
DB_PORT=5432
DB_NAME=scanops
DB_USER=scanops
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# === Redis Cache ===
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# === JWT & Security ===
JWT_SECRET_KEY=CHANGE_ME_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# === Domain Configuration ===
PLATFORM_URL=https://scanops.example.com
FRONTEND_URL=https://scanops.example.com
API_BASE_URL=https://scanops.example.com/api

# ========== OPTIONAL BUT RECOMMENDED ==========

# === AI / Ollama ===
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral:7b
OLLAMA_TIMEOUT=300
OLLAMA_TEMPERATURE=0.7

# === Vault (Secrets Management) ===
VAULT_ENABLED=false
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=CHANGE_ME_IF_USING
VAULT_SKIP_VERIFY=false

# === Logging ===
LOG_LEVEL=info
LOG_FORMAT=json
LOG_TO_FILE=true
LOG_FILE_PATH=/var/log/scanops/app.log

# === CORS Configuration ===
CORS_ORIGINS=https://scanops.example.com
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# === SIEM Integration ===
# Wazuh
WAZUH_ENABLED=false
WAZUH_API_URL=https://wazuh-manager:55000
WAZUH_USER=wazuh
WAZUH_PASSWORD=CHANGE_ME_IF_USING
WAZUH_VERIFY_SSL=false

# Graylog
GRAYLOG_ENABLED=false
GRAYLOG_API_URL=http://graylog:9000/api
GRAYLOG_API_TOKEN=CHANGE_ME_IF_USING

# === External Scanners ===
ZAP_ENABLED=false
ZAP_HOST=zap
ZAP_PORT=8080
ZAP_API_KEY=CHANGE_ME_IF_USING

# === Notifications ===
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === SMTP (Email Notifications) ===
SMTP_ENABLED=false
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASSWORD=CHANGE_ME_IF_USING
SMTP_FROM=scanops@example.com
SMTP_FROM_NAME=ScanOPS

# === Nginx Configuration ===
NGINX_WORKER_PROCESSES=auto
NGINX_CLIENT_MAX_BODY_SIZE=100M
NGINX_KEEPALIVE_TIMEOUT=65

# === SSL/TLS ===
SSL_ENABLED=true
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem
SSL_PROTOCOLS=TLSv1.2 TLSv1.3

# === Rate Limiting ===
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GENERAL=10r/s
RATE_LIMIT_API=30r/s
RATE_LIMIT_UPLOAD=5r/m

# === Monitoring ===
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090
SENTRY_ENABLED=false
SENTRY_DSN=

# === Performance Tuning ===
WORKER_THREADS=4
DB_POOL_MIN=2
DB_POOL_MAX=20
REDIS_POOL_SIZE=10

# === Feature Flags ===
FEATURE_NETWORK_SCAN=true
FEATURE_VULN_ASSESSMENT=true
FEATURE_COMPLIANCE_CHECK=true
FEATURE_SURFACE_DISCOVERY=true

# ========== Generation Instructions ==========
#
# Generate strong passwords:
#   openssl rand -base64 32
#
# Generate JWT secret:
#   openssl rand -hex 32
#
# SMTP Password (Gmail):
#   - Use App Passwords: https://myaccount.google.com/apppasswords
#   - NOT your regular Gmail password
#
# ========== Security Checklist ==========
# Before deploying, verify:
# ☐ DB_PASSWORD is 32+ characters
# ☐ JWT_SECRET_KEY is 32+ characters
# ☐ REDIS_PASSWORD is 32+ characters
# ☐ PLATFORM_URL is correct domain
# ☐ SSL certificates are valid
# ☐ .env.production is in .gitignore
# ☐ NODE_ENV=production
# ☐ LOG_LEVEL is not debug
