# ===== PRODUCTION ENVIRONMENT =====
# Copy to .env.production and replace placeholders with real values
# NEVER commit .env.production with real secrets

# ===== DATABASE =====
DB_HOST=postgres
DB_PORT=5432
DB_NAME=scanops
DB_USER=scanops
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ===== REDIS =====
REDIS_URL=redis://scanops-main-redis:6379/0
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ===== JWT & SECURITY =====
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ===== AI / OLLAMA =====
# For Linux server: use host network or update IP
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b
OLLAMA_TIMEOUT=300

# ===== VAULT (Optional) =====
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=CHANGE_ME_VAULT_TOKEN
VAULT_SKIP_VERIFY=false

# ===== NOTIFICATIONS (Optional) =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== EXTERNAL URLs =====
PLATFORM_URL=https://scanops.example.com
FRONTEND_URL=https://scanops.example.com
API_BASE_URL=https://scanops.example.com/api

# ===== LOGGING =====
LOG_LEVEL=info
LOG_FORMAT=json

# ===== CORS =====
CORS_ORIGINS=https://scanops.example.com

# ===== EXTERNAL SCANNERS (Optional) =====
ZAP_HOST=scanops-zap
ZAP_PORT=8080
ZAP_API_KEY=CHANGE_ME_ZAP_API_KEY

# ===== SIEM INTEGRATION =====
WAZUH_API_URL=https://wazuh-manager:55000
WAZUH_USER=wazuh
WAZUH_PASSWORD=CHANGE_ME_WAZUH_PASSWORD

GRAYLOG_API_URL=http://graylog:9000/api
GRAYLOG_API_TOKEN=CHANGE_ME_GRAYLOG_TOKEN

# ===== SMTP (Optional) =====
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM=scanops@example.com
